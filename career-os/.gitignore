# User content (always private)
# NOTE: `Dir/*` (not `Dir/`) so git still traverses the dir and the
# `!**/.gitkeep` exception below keeps the directory stubs visible.
Impact-Library/*
Stories/*
Applications/*
Companies/*
Learnings/*
Resumes/*

# Generator artifacts
generator/node_modules/
generator/output/
generator/*.pdf

# Keep directory stubs visible after clone
!**/.gitkeep

# Health reports
.health/

# Local config
.claude/settings.local.json

# OS files
.DS_Store
