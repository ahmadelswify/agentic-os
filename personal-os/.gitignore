# User content (always private)
# NOTE: `Dir/*` (not `Dir/`) so git still traverses the dir and the
# `!**/.gitkeep` exception below keeps the directory stubs visible.
Tasks/*
Inbox/*
Knowledge/*
Projects/*
Archive/*

# Keep directory stubs visible after clone
!**/.gitkeep

# Per-user files (templates ship, personal versions don't)
GOALS.md
INBOX.md
!GOALS-template.md
!inbox-template.md

# Health reports
.health/

# Local config
.claude/settings.local.json

# OS files
.DS_Store
